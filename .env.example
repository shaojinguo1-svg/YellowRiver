# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upload signing
# Generate a long random value that is independent from Supabase keys.
APPLICATION_UPLOAD_SIGNING_SECRET=replace-with-32-byte-random-secret

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Resend (Email)
RESEND_API_KEY=re_your_api_key
ADMIN_EMAIL=admin@yellowriver.com

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=YellowRiver

# Bootstrap scripts (caller-provided; scripts never print passwords)
# ADMIN_EMAIL above is also used by scripts/create-admin.ts and scripts/seed-properties.ts.
ADMIN_PASSWORD=replace-with-temporary-admin-password
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User
TENANT_EMAIL=tenant@example.com
TENANT_PASSWORD=replace-with-temporary-tenant-password
TENANT_FIRST_NAME=Tenant
TENANT_LAST_NAME=User
SEED_ADMIN_EMAIL=admin@yellowriver.com
